<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CryptoEHR Secure Portal</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-gray-900 text-gray-100 min-h-screen font-sans">

    <div class="container mx-auto px-4 py-8 max-w-4xl">
        <header class="text-center mb-10">
            <h1 class="text-4xl font-extrabold tracking-tight text-indigo-400">SignatureEHR System</h1>
            <p class="text-gray-400 mt-2 text-sm">Schnorr Cryptographic Verification Engine</p>
        </header>

        <div id="login-screen" class="bg-gray-800 p-8 rounded-xl shadow-2xl border border-gray-700 max-w-md mx-auto">
            <h2 id="auth-title" class="text-2xl font-bold mb-6 text-center text-white">System Authentication</h2>

            <div class="flex gap-2 mb-6 p-1 bg-gray-900 rounded-lg">
                <button id="tab-admin" onclick="setRole('admin')" class="w-1/2 py-2 rounded-md font-medium text-center bg-indigo-600 text-white transition cursor-pointer">Admin</button>
                <button id="tab-patient" onclick="setRole('patient')" class="w-1/2 py-2 rounded-md font-medium text-center text-gray-400 hover:text-white transition cursor-pointer">Patient</button>
            </div>

            <form id="login-form" onsubmit="handleAuthSubmit(event)" class="space-y-4">
                <div>
                    <label class="block text-xs font-semibold uppercase tracking-wider text-gray-400 mb-1">User ID / Username</label>
                    <input type="text" id="username" required class="w-full bg-gray-900 border border-gray-700 rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-indigo-500">
                </div>
                <div>
                    <label class="block text-xs font-semibold uppercase tracking-wider text-gray-400 mb-1">Password</label>
                    <input type="password" id="password" required class="w-full bg-gray-900 border border-gray-700 rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-indigo-500">
                </div>
                <button type="submit" id="auth-submit-btn" class="w-full bg-indigo-600 hover:bg-indigo-500 text-white font-semibold py-3 rounded-lg transition mt-4 shadow-lg cursor-pointer">
                    Authenticate Session
                </button>
            </form>

            <div class="text-center mt-6 text-sm text-gray-400 border-t border-gray-700/60 pt-4">
                <p id="toggle-text">Don't have an account?</p>
                <button onclick="toggleAuthMode()" id="toggle-mode-btn" class="text-indigo-400 font-medium hover:underline mt-1 cursor-pointer">Create an account here</button>
            </div>
        </div>

        <div id="dashboard-screen" class="hidden bg-gray-800 p-8 rounded-xl shadow-2xl border border-gray-700 text-center">
            <div class="flex justify-between items-center mb-6 border-b border-gray-700 pb-4">
                <span id="welcome-text" class="font-medium text-gray-300">Welcome, User</span>
                <button onclick="logout()" class="text-xs bg-red-900/40 border border-red-700 hover:bg-red-800 text-red-300 px-3 py-1.5 rounded-md transition cursor-pointer">Sign Out</button>
            </div>

            <h3 class="text-xl font-bold mb-6">Select Cryptographic Operation</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <button onclick="showScreen('sign-screen')" class="p-6 bg-gray-900 border border-gray-700 rounded-xl hover:border-indigo-500 transition group text-left cursor-pointer">
                    <div class="text-indigo-400 text-3xl mb-3">✍️</div>
                    <h4 class="text-lg font-bold group-hover:text-indigo-400 transition">Digitally Sign File</h4>
                    <p class="text-sm text-gray-400 mt-1">Signed using your authenticated account's key.</p>
                </button>
                <button onclick="showScreen('verify-screen')" class="p-6 bg-gray-900 border border-gray-700 rounded-xl hover:border-emerald-500 transition group text-left cursor-pointer">
                    <div class="text-emerald-400 text-3xl mb-3">🛡️</div>
                    <h4 class="text-lg font-bold group-hover:text-emerald-400 transition">Verify signed file</h4>
                    <p class="text-sm text-gray-400 mt-1">Cryptographically audit any previously signed file.</p>
                </button>
            </div>
        </div>

        <div id="sign-screen" class="hidden bg-gray-800 p-8 rounded-xl shadow-2xl border border-gray-700">
            <button onclick="showScreen('dashboard-screen')" class="mb-6 text-sm text-indigo-400 hover:underline cursor-pointer">← Back to Options</button>
            <h2 class="text-2xl font-bold mb-6 text-white border-b border-gray-700 pb-2">File Signature Initialization</h2>

            <form id="sign-form" onsubmit="handleSign(event)" class="space-y-4">
                <div>
                    <label class="block text-xs font-semibold text-gray-400 mb-1">FILE ID</label>
                    <input type="text" id="sign-file-id" required class="w-full bg-gray-900 border border-gray-700 rounded-lg px-4 py-2 text-white focus:outline-none focus:border-indigo-500">
                    <p class="text-[11px] text-gray-500 mt-1">Signed using your authenticated account's key — not a client-supplied identity.</p>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-400 mb-1">TARGET RECORD FILE</label>
                    <input type="file" id="sign-file" required class="w-full bg-gray-900 border border-gray-700 rounded-lg px-4 py-2 text-white focus:outline-none focus:border-indigo-500 file:mr-4 file:py-1 file:px-3 file:rounded-md file:border-0 file:text-xs file:font-semibold file:bg-indigo-900 file:text-indigo-300 hover:file:bg-indigo-800 cursor-pointer">
                </div>
                <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-500 text-white font-semibold py-2.5 rounded-lg transition cursor-pointer">Run Digital Execution</button>
            </form>

            <div id="sign-result" class="hidden mt-6 bg-gray-900 p-4 rounded-lg border border-indigo-500/30">
                <h4 class="text-indigo-400 font-bold mb-2 text-sm tracking-wide">GENERATED SIGNATURE DATA</h4>
                <p class="text-xs text-gray-400 mb-3">Copy these exact parameters to verify the file signature on the next panel.</p>
                <div class="space-y-2 text-xs font-mono select-all">
                    <div><span class="text-gray-500">R:</span> <p id="out-r" class="bg-gray-950 p-1.5 rounded break-all"></p></div>
                    <div><span class="text-gray-500">R_blinded:</span> <p id="out-rb" class="bg-gray-950 p-1.5 rounded break-all"></p></div>
                    <div><span class="text-gray-500">Final Hash:</span> <p id="out-fh" class="bg-gray-950 p-1.5 rounded break-all"></p></div>
                    <div><span class="text-gray-500">User Public Key:</span> <p id="out-upk" class="bg-gray-950 p-1.5 rounded break-all"></p></div>
                    <div><span class="text-gray-500">Application Public Key:</span> <p id="out-apk" class="bg-gray-950 p-1.5 rounded break-all"></p></div>
                </div>
            </div>
        </div>

        <div id="verify-screen" class="hidden bg-gray-800 p-8 rounded-xl shadow-2xl border border-gray-700">
            <button onclick="showScreen('dashboard-screen')" class="mb-6 text-sm text-emerald-400 hover:underline cursor-pointer">← Back to Options</button>
            <h2 class="text-2xl font-bold mb-6 text-white border-b border-gray-700 pb-2">Cryptographic Audit Ledger</h2>

            <form id="verify-form" onsubmit="handleVerify(event)" class="space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-semibold text-gray-400 mb-1">USER ID</label>
                        <input type="text" id="v-user-id" required class="w-full bg-gray-900 border border-gray-700 rounded-lg px-4 py-1.5 text-white font-mono text-sm focus:border-emerald-500 focus:outline-none">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-gray-400 mb-1">FILE ID</label>
                        <input type="text" id="v-file-id" required class="w-full bg-gray-900 border border-gray-700 rounded-lg px-4 py-1.5 text-white font-mono text-sm focus:border-emerald-500 focus:outline-none">
                    </div>
                </div>

                <div class="space-y-3 p-4 bg-gray-900/60 border border-gray-700 rounded-xl">
                    <span class="text-xs text-emerald-400 font-bold uppercase tracking-wider block">Required Cryptographic Public Values</span>
                    <div>
                        <label class="block text-[10px] text-gray-400 mb-0.5">USER PUBLIC KEY</label>
                        <input type="text" id="v-upk" required class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-1 text-xs font-mono text-white focus:border-emerald-500 focus:outline-none">
                    </div>
                    <div>
                        <label class="block text-[10px] text-gray-400 mb-0.5">APPLICATION PUBLIC KEY</label>
                        <input type="text" id="v-apk" required class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-1 text-xs font-mono text-white focus:border-emerald-500 focus:outline-none">
                    </div>
                    <div>
                        <label class="block text-[10px] text-gray-400 mb-0.5">R</label>
                        <input type="text" id="v-r" required class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-1 text-xs font-mono text-white focus:border-emerald-500 focus:outline-none">
                    </div>
                    <div>
                        <label class="block text-[10px] text-gray-400 mb-0.5">R_BLINDED</label>
                        <input type="text" id="v-rb" required class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-1 text-xs font-mono text-white focus:border-emerald-500 focus:outline-none">
                    </div>
                    <div>
                        <label class="block text-[10px] text-gray-400 mb-0.5">FINAL HASH</label>
                        <input type="text" id="v-finalhash" required class="w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-1 text-xs font-mono text-white focus:border-emerald-500 focus:outline-none">
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-semibold text-gray-400 mb-1">UPLOAD SIGNED TARGET FILE</label>
                    <input type="file" id="v-file" required class="w-full bg-gray-900 border border-gray-700 rounded-lg px-4 py-2 text-white text-sm file:mr-4 file:py-1 file:px-3 file:rounded-md file:border-0 file:text-xs file:font-semibold file:bg-emerald-900 file:text-emerald-300 hover:file:bg-emerald-800 cursor-pointer">
                </div>

                <button type="submit" class="w-full bg-emerald-600 hover:bg-emerald-500 text-white font-semibold py-2.5 rounded-lg transition cursor-pointer">Validate Cryptographic Integrity</button>
            </form>

            <div id="verify-result" class="hidden mt-6 p-4 rounded-lg text-center font-bold text-lg border"></div>
        </div>
    </div>

    <script>
        const API_URL = "";
        let currentRole = "admin";
        let authMode = "login"; // 'login' or 'register'

        function showScreen(screenId) {
            ['login-screen', 'dashboard-screen', 'sign-screen', 'verify-screen'].forEach(id => {
                document.getElementById(id).classList.add('hidden');
            });
            document.getElementById(screenId).classList.remove('hidden');
        }

        function setRole(role) {
            currentRole = role;
            const adminBtn = document.getElementById('tab-admin');
            const patientBtn = document.getElementById('tab-patient');
            if (role === 'admin') {
                adminBtn.className = "w-1/2 py-2 rounded-md font-medium text-center bg-indigo-600 text-white transition cursor-pointer";
                patientBtn.className = "w-1/2 py-2 rounded-md font-medium text-center text-gray-400 hover:text-white transition cursor-pointer";
            } else {
                patientBtn.className = "w-1/2 py-2 rounded-md font-medium text-center bg-indigo-600 text-white transition cursor-pointer";
                adminBtn.className = "w-1/2 py-2 rounded-md font-medium text-center text-gray-400 hover:text-white transition cursor-pointer";
            }
        }

        function toggleAuthMode() {
            const title = document.getElementById('auth-title');
            const submitBtn = document.getElementById('auth-submit-btn');
            const toggleText = document.getElementById('toggle-text');
            const toggleBtn = document.getElementById('toggle-mode-btn');

            if (authMode === "login") {
                authMode = "register";
                title.innerText = "Create Secure Account";
                submitBtn.innerText = "Register New Account";
                toggleText.innerText = "Already have an account?";
                toggleBtn.innerText = "Log in here";
            } else {
                authMode = "login";
                title.innerText = "System Authentication";
                submitBtn.innerText = "Authenticate Session";
                toggleText.innerText = "Don't have an account?";
                toggleBtn.innerText = "Create an account here";
            }
        }

        async function handleAuthSubmit(e) {
            e.preventDefault();
            const username = document.getElementById('username').value;
            const password = document.getElementById('password').value;
            const endpoint = authMode === "login" ? "/login" : "/register";

            try {
                const response = await fetch(`${API_URL}${endpoint}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',
                    body: JSON.stringify({ username, password, role: currentRole })
                });
                const data = await response.json();

                if (response.ok) {
                    if (authMode === "register") {
                        alert("Account provisioned successfully! You can now log in.");
                        toggleAuthMode(); // Switch back to login view automatically
                        document.getElementById('password').value = "";
                    } else {
                        document.getElementById('welcome-text').innerText = `Session: ${data.username} (${data.role.toUpperCase()})`;
                        showScreen('dashboard-screen');
                    }
                } else {
                    alert(data.error || "Authentication Mismatch");
                }
            } catch (err) {
                alert("Cannot connect to backend server instances.");
            }
        }

        async function logout() {
            try {
                await fetch(`${API_URL}/logout`, { method: 'POST', credentials: 'include' });
            } catch (err) {
                // Ignore network errors here - we still clear the local UI state below.
            }
            document.getElementById('login-form').reset();
            authMode = "login";
            document.getElementById('auth-title').innerText = "System Authentication";
            document.getElementById('auth-submit-btn').innerText = "Authenticate Session";
            document.getElementById('toggle-text').innerText = "Don't have an account?";
            document.getElementById('toggle-mode-btn').innerText = "Create an account here";
            showScreen('login-screen');
        }

        async function handleSign(e) {
            e.preventDefault();
            const formData = new FormData();
            formData.append('file_id', document.getElementById('sign-file-id').value);
            formData.append('file', document.getElementById('sign-file').files[0]);

            try {
                const response = await fetch(`${API_URL}/sign`, {
                    method: 'POST',
                    credentials: 'include',
                    body: formData
                });
                const data = await response.json();
                if (response.ok) {
                    document.getElementById('sign-result').classList.remove('hidden');
                    document.getElementById('out-r').innerText = data.R;
                    document.getElementById('out-rb').innerText = data.R_blinded;
                    document.getElementById('out-fh').innerText = data.final_hash;
                    document.getElementById('out-upk').innerText = data.user_public_key;
                    document.getElementById('out-apk').innerText = data.app_public_key;
                } else {
                    alert(data.error);
                }
            } catch (err) {
                alert("Error calling signature initialization API.");
            }
        }

        async function handleVerify(e) {
            e.preventDefault();
            const formData = new FormData();
            formData.append('user_id', document.getElementById('v-user-id').value);
            formData.append('file_id', document.getElementById('v-file-id').value);
            formData.append('user_public_key', document.getElementById('v-upk').value);
            formData.append('app_public_key', document.getElementById('v-apk').value);
            formData.append('R', document.getElementById('v-r').value);
            formData.append('R_blinded', document.getElementById('v-rb').value);
            formData.append('final_hash', document.getElementById('v-finalhash').value);
            formData.append('file', document.getElementById('v-file').files[0]);

            try {
                const response = await fetch(`${API_URL}/verify`, {
                    method: 'POST',
                    credentials: 'include',
                    body: formData
                });
                const data = await response.json();
                const targetDiv = document.getElementById('verify-result');
                targetDiv.classList.remove('hidden');

                if (data.valid === true) {
                    targetDiv.className = "mt-6 p-4 rounded-lg text-center font-bold text-lg bg-emerald-950/50 border border-emerald-500 text-emerald-400";
                    targetDiv.innerText = "✓ Valid Signature Verified Successfully.";
                } else {
                    targetDiv.className = "mt-6 p-4 rounded-lg text-center font-bold text-lg bg-red-950/50 border border-red-500 text-red-400";
                    targetDiv.innerText = "✕ Invalid Signature! Threat Detected or Verification Mismatch.";
                }
            } catch (err) {
                alert("Error posting verification stream payload.");
            }
        }
    </script>
</body>
</html>
